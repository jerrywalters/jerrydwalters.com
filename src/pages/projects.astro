---
import Base from '../layouts/Base.astro';
import { getProjects } from '../lib/projects';

const projects = getProjects();
---

<Base title="Projects · Jerry Walters" fixed={false}>
  <section class="projects">
    <h1>projects</h1>
    <p class="lede">Little apps and game prototypes. Built to see what sticks.</p>

    {
      projects.length === 0 ? (
        <p class="empty">Nothing here yet — check back soon.</p>
      ) : (
        <ul class="grid">
          {projects.map((p) => (
            <li>
              <a href={`/${p.slug}/`}>
                <span class="title">{p.title}</span>
                {p.blurb && <span class="blurb">{p.blurb}</span>}
                <span class="tier">{p.tier}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </section>
</Base>

<style>
  .projects {
    max-width: 46rem;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
  }

  h1 {
    font-size: 1.6rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    margin: 0 0 0.4rem;
  }

  .lede {
    color: var(--muted);
    margin: 0 0 2.5rem;
    font-size: 0.95rem;
  }

  .empty {
    color: var(--muted);
  }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
    gap: 0.75rem;
  }

  .grid a {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    height: 100%;
    padding: 1.1rem 1.2rem;
    border: 1px solid var(--hairline);
    border-radius: 0.75rem;
    color: var(--fg);
    text-decoration: none;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .grid a:hover {
    border-color: var(--fg);
    transform: translateY(-2px);
  }

  .title {
    font-weight: 600;
  }

  .blurb {
    color: var(--muted);
    font-size: 0.88rem;
    line-height: 1.35;
  }

  .tier {
    margin-top: auto;
    align-self: flex-start;
    font-size: 0.66rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border: 1px solid var(--hairline);
    border-radius: 999px;
    padding: 0.1rem 0.5rem;
  }
</style>
