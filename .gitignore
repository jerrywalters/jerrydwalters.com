# build output
dist/
.astro/
.wrangler/

# per-project build artifacts (assembled into root dist/ at build time)
projects/*/dist/

# deps
node_modules/

# env / secrets
.env
.env.*
!.env.example

# misc
.DS_Store
*.log
.vscode/*
!.vscode/extensions.json

# git worktrees (parallel agents)
.worktrees/

# Claude: ignore local-only bits, but keep shared config (skills, commands,
# settings.json) committable so all agents pick it up.
.claude/launch.json
.claude/settings.local.json
